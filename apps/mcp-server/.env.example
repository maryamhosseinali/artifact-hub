# Same Postgres connection string as apps/web
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Anthropic API key — used server-side only for auto-tagging and feedback summarization
ANTHROPIC_API_KEY="sk-ant-..."

# Shared secret typed into the one-time OAuth consent screen when a client
# (e.g. Claude Desktop) connects (generate with: openssl rand -hex 32)
MCP_AUTHORIZE_SECRET="change-me"

# Client secret for the one pre-registered OAuth client (client_id "artifact-hub"),
# for connectors that want a fixed Client ID/Secret instead of self-registering
# via Dynamic Client Registration (generate with: openssl rand -hex 32)
MCP_CLIENT_SECRET="change-me-too"

# Public HTTPS URL of THIS mcp-server deployment (used as the OAuth issuer/
# base URL for metadata discovery — must be reachable by MCP clients)
MCP_PUBLIC_URL="https://your-mcp-server.up.railway.app"

# Base URL of the deployed web app, used to build share/artifact links returned by tools
WEB_BASE_URL="https://your-app.vercel.app"

# Port the MCP server listens on (Railway sets this automatically)
PORT=3001
